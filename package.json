{
  "name": "storypoker",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite --host",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:unit:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test tests/e2e/smoke.spec.ts",
    "test:e2e:ui": "playwright test --ui",
    "test:ci": "npm run lint && npm run typecheck && npm run test:unit && npm run build",
    "deploy:stage": "npx -y netlify-cli@latest deploy --alias stage",
    "deploy:prod": "npx -y netlify-cli@latest deploy --prod"
  },
  "devDependencies": {
    "@iconify-json/ic": "^1.2.4",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^25.9.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.7",
    "@vue/eslint-config-typescript": "^14.7.0",
    "autoprefixer": "^10.5.0",
    "dotenv": "^17.4.2",
    "eslint": "^10.4.1",
    "eslint-plugin-vue": "^10.9.1",
    "happy-dom": "^20.9.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.0",
    "vite": "^8.0.14",
    "vitest": "^4.1.7",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.3.3"
  },
  "dependencies": {
    "@dicebear/collection": "^9.4.2",
    "@dicebear/core": "^9.4.2",
    "@iconify/vue": "^5.0.1",
    "@lucide/vue": "^1.17.0",
    "@supabase/supabase-js": "^2.106.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "pinia": "^3.0.4",
    "reka-ui": "^2.9.8",
    "shadcn-vue": "^2.7.3",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "v-wave": "^3.0.4",
    "vue": "^3.5.35",
    "vue-i18n": "^11.4.4",
    "vue-router": "^5.1.0"
  },
  "engines": {
    "node": ">=24.15.0",
    "npm": ">=11.12.0"
  }
}
